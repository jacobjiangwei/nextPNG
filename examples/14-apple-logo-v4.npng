npng: "0.1"
canvas:
  width: 400
  height: 480
  background: "#FFFFFF"
layers:
  - name: "apple-logo"
    elements:
      # Apple body — right lobe, bite, left lobe, bottom, top indentation
      - type: path
        d: "M 200 100
            C 220 100 244 108 256 120
            C 274 138 288 162 292 186
            C 296 210 296 230 290 248
            C 284 266 275 278 264 290
            C 250 306 240 324 238 346
            C 236 358 232 368 222 376
            C 214 382 208 384 200 384
            C 192 384 186 382 178 376
            C 168 368 164 358 162 346
            C 160 324 150 306 136 290
            C 125 278 116 266 110 248
            C 104 230 104 210 108 186
            C 112 162 126 138 144 120
            C 156 108 180 100 200 100 Z"
        fill: "#333333"
      # Bite cutout (white ellipse on right side)
      - type: ellipse
        cx: 304
        cy: 220
        rx: 36
        ry: 48
        fill: "#FFFFFF"
      # Leaf
      - type: path
        d: "M 200 105
            C 200 85 210 60 232 40
            C 252 22 268 16 276 14
            C 276 34 268 58 248 76
            C 232 92 214 104 200 105 Z"
        fill: "#333333"
